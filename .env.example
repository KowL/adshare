# adshare 环境变量配置
# 复制为 .env 并填入实际值

# ============================================
# AmazingData 登录信息（必填）
# ============================================
AD_USERNAME=your_username
AD_PASSWORD=your_password
AD_HOST=your_server_ip
AD_PORT=8600

# ============================================
# 服务配置
# ============================================
ADSHARE_HOST=0.0.0.0
ADSHARE_PORT=8000
ADSHARE_LOG_LEVEL=INFO

# API 认证（可选，内网可关闭）
ADSHARE_API_KEY=your_api_key_here

# ============================================
# Redis 缓存配置
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 缓存 TTL（秒）
CACHE_TTL_SHORT=300
CACHE_TTL_MEDIUM=3600
CACHE_TTL_LONG=86400

# ============================================
# 本地缓存配置
# ============================================
LOCAL_CACHE_PATH=./cache
LOCAL_CACHE_ENABLED=true

# ============================================
# 限流配置
# ============================================
RATE_LIMIT_PER_MINUTE=120

# ============================================
# MCP 配置（可选）
# ============================================
MCP_ENABLED=true
MCP_TRANSPORT=sse
