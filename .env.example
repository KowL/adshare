# adshare 双服务环境变量配置
# 复制为 .env 并填入实际值
#
# 服务架构:
#   adshare-api        : FastAPI HTTP API (任意平台)
#   amazingdata-worker : AmazingData SDK 数据拉取 (必须 linux/amd64)
#
# 注意: API 和 Worker 共享 Redis 和 L3 数据卷，但环境变量可独立配置

# ============================================
# AmazingData 登录信息（Worker 服务必填）
# ============================================
AD_USERNAME=your_username
AD_PASSWORD=your_password
AD_HOST=your_server_ip
AD_PORT=8600

# ============================================
# 服务配置
# ============================================
ADSHARE_HOST=0.0.0.0
ADSHARE_PORT=8000
ADSHARE_LOG_LEVEL=INFO

# API 认证（可选，内网可关闭）
ADSHARE_API_KEY=your_api_key_here

# ============================================
# Redis 缓存配置
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 缓存 TTL（秒）— Redis 仅用于实时/订阅行情
CACHE_TTL_REALTIME=300
CACHE_KEY_PREFIX=adshare

# ============================================
# 限流配置
# ============================================
RATE_LIMIT_PER_MINUTE=120

# ============================================
# L3 历史数据仓
# ============================================
HISTORICAL_ENABLED=true
HISTORICAL_PATH=./data
HISTORICAL_RETENTION_YEARS=0

# DuckDB 配置
DUCKDB_MODE=memory
DUCKDB_FILE_PATH=./data/duckdb/adshare.duckdb
DUCKDB_MAX_ROWS=100000
DUCKDB_QUERY_TIMEOUT=30

# ============================================
# Worker 同步调度配置
# ============================================
# AmazingData SDK 本地数据缓存目录（容器内路径）。
# InfoData/DownloadInfoData 会把 HDF5 缓存放在该目录下。
AMAZINGDATA_LOCAL_PATH=/app/data/amazingdata

SYNC_SCHEDULE_ENABLED=true
SYNC_KLINE_DAILY_HOUR=17
SYNC_KLINE_DAILY_MINUTE=10
SYNC_KLINE_WEEKLY_HOUR=19
SYNC_KLINE_WEEKLY_MINUTE=30
SYNC_KLINE_MONTHLY_HOUR=20
SYNC_KLINE_MONTHLY_MINUTE=0
SYNC_META_CODES_HOUR=8
SYNC_META_CODES_MINUTE=0
# 参考数据同步（股东人数周六 03:00、指数成分周六 04:00）
SYNC_SHAREHOLDER_DAY_OF_WEEK=sat
SYNC_SHAREHOLDER_HOUR=3
SYNC_SHAREHOLDER_MINUTE=0
SYNC_INDEX_COMPONENT_DAY_OF_WEEK=sat
SYNC_INDEX_COMPONENT_HOUR=4
SYNC_INDEX_COMPONENT_MINUTE=0
SYNC_WORKERS=4
SYNC_RETRY_ATTEMPTS=3

# 指数成分同步的指数列表（逗号分隔，留空用内置默认列表）
INDEX_CODES=

# 启动时立即执行一次同步
SYNC_ON_START=true

# 实时行情订阅开关（Worker）
# IMPORTANT: TGW 账号最大并发连接数为 1 时，实时订阅和历史同步不能同时运行。
# 盘后同步数据请保持 false；盘中需要实时行情时再改为 true，并先停止历史同步 worker。
REALTIME_ENABLED=false

# ============================================
# L3 历史数据仓维护 (idempotent repair)
# ============================================
# Enabled by default — the routines are no-ops on already-clean data,
# so a missed run is harmless. They now also repair K-line price
# anomalies (e.g. zero low/close on non-suspended bars).
MAINTENANCE_SCHEDULE_ENABLED=true
# Run kline + codes repair weekly on Sunday at 03:00 (Asia/Shanghai)
MAINTENANCE_KLINE_DAY_OF_WEEK=sun
MAINTENANCE_KLINE_HOUR=3
MAINTENANCE_KLINE_MINUTE=0
# Run financial-table repair weekly on Sunday at 04:00 (Asia/Shanghai)
MAINTENANCE_FINANCIAL_DAY_OF_WEEK=sun
MAINTENANCE_FINANCIAL_HOUR=4
MAINTENANCE_FINANCIAL_MINUTE=0
