# Copy to amazingdata/realtime.env and fill in. gitignored — never commit.
# realtime（盘中）服务专用 TGW 账号；须与 batch.env 的账号不同，
# 两个服务即可同时运行（TGW 单连接约束是按账号计算的）。
AD_USERNAME=your_realtime_username
AD_PASSWORD=your_realtime_password
AD_HOST=your_server_ip
AD_PORT=8600
AD_MAX_RETRIES=3

# Redis（实时行情写入，与 adshare API 读取共用）
REDIS_HOST=your_redis_host
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# K线订阅周期（JSON 数组，可选 min1/min5/min15/min30/min60/day）
REALTIME_KLINE_PERIODS=["min1","min5","min15","min30","min60"]

# K 线历史 Stream（tushare rt_min 数据源）
# TTL：1 天（盘后自然过期）；MAXLEN：单只单周期最多保留 240 根
REALTIME_KLINE_HISTORY_TTL=86400
REALTIME_KLINE_MAX_BARS=240
