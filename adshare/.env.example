# Copy to adshare/.env and fill in.
# Shared with worker for: REDIS_*, HISTORICAL_*, DUCKDB_*, ADSHARE_*.
# Worker-only vars (AD_*, SYNC_*, REALTIME_*, MAINTENANCE_*) live in amazingdata/.env.

ADSHARE_HOST=0.0.0.0
ADSHARE_PORT=8000
ADSHARE_LOG_LEVEL=INFO

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

CACHE_TTL_REALTIME=300
CACHE_KEY_PREFIX=adshare

RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_PER_SECOND=10

AUTH_ENABLED=false
ADSHARE_API_KEY=

METRICS_ENABLED=true
METRICS_PATH=/metrics

HISTORICAL_ENABLED=true
HISTORICAL_PATH=./data
DUCKDB_MODE=memory
DUCKDB_FILE_PATH=./data/duckdb/adshare.duckdb

KLINE_MAX_LIMIT=10000
MAX_CODES_PER_QUERY=50
DEFAULT_BEGIN_DATE=19900101
