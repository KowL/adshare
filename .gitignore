# Logs and cache
logs/*.log
cache/*.parquet
!logs/.gitkeep
!cache/.gitkeep

# Local/remote environment files (NEVER commit — contain secrets)
.env
.env.remote-api
PY

# Package .env files (contain Redis password / SDK login / API key)
# Ignored by the root ".env" rule above, but listed explicitly for clarity.
/adshare/.env
/amazingdata/.env
/amazingdata/realtime.env
/amazingdata/batch.env

# Local data
cache/
data/
!data/.gitkeep
*.db
*.sqlite3

# Binary dependencies (amazingdata SDK wheels inside amazingdata/wheels/)
# NOTE: whl files are vendor binaries — do NOT commit. They live in
# amazingdata/wheels/ and are installed into the Docker base image
# (amazingdata/base.Dockerfile) at build time.
amazingdata/wheels/*.whl
*.whl
